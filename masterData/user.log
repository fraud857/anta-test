    apiBaseUrl: http://aop-test.antaapi.com/ASH24111208564609
    appCode: ASH25101309132431
    secretKey: 5c3ce657c7fb4c29aa06c6d35df5eee9
    mdmAppCode: SYSID0432

    # ==================== 组织数据同步 | 每天 01:00 ====================
    orgSyncEnabled: true
    orgSyncCron: "0 0 1 * * ?"
    orgBatchSize: 100

    # ==================== 人员全量同步 | 每天 01:30 ====================
    personSyncEnabled: true
    personSyncCron: "0 30 1 * * ?"

    # ==================== 离职/调岗同步 | 每2小时 ====================
    resignationSyncEnabled: true
    cron: "0 0 */2 * * ?"
    resignationBatchSize: 100
    transferEnabled: true
    transferSyncCron: "0 0 */2 * * ?"
    transferBatchSize: 100
    appOrgCodes: 20215819
    hrPersonInfoQueryUrl: ""

    # ==================== 3PI离职同步 | 每2小时 ====================
    threePiResignationSyncEnabled: false
    threePiResignationCron: "0 0 */2 * * ?"
    threePiBatchSize: 100
