server:
  port: 8080
  servlet:
    encoding:
      force-response: true
      charset: UTF-8
      enabled: true

http:
  httpMaxTotal: 100
  httpDefaultMaxPerRoute: 4
  httpConnectTimeout: 1000
  httpConnectionRequestTimeout: 500
  httpSocketTimeout: 10000

mybatis-plus:
  configuration:
    map-underscore-to-camel-case: true
    #确保:在查询结果map映射中，当value=null时仍保留字段映射
    call-setters-on-nulls: true
    log-impl: org.apache.ibatis.logging.slf4j.Slf4jImpl
  mapperLocations: classpath:mapper/*.xml

spring:
  #i18n#
  messages:
    basename: i18n/messages #相对路径 开头请勿添加斜杠
  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 100MB
  #datasource#
  datasource:
    dynamic:
      hikari:
        max-pool-size: 20
        connection-test-query: select 1
      #default datasource#
      primary: cyberdata
      datasource:
        cyberdata:
          driver-class-name: com.mysql.cj.jdbc.Driver
          url: jdbc:mysql://10.131.2.34:3306/cyberdata_user?useUnicode=true&characterEncoding=utf8&autoReconnect=true&allowMultiQueries=true&serverTimezone=Asia/Shanghai&useAffectedRows=true&zeroDateTimeBehavior=CONVERT_TO_NULL&useSSL=false
          username: cyberdata_user
          password: cyber!P4D7,aNMh
  quartz:
    properties:
      org:
        quartz:
          scheduler:
            instanceName: clusteredScheduler
            instanceId: AUTO
            makeSchedulerThreadDaemon: true
          jobStore:
            #useProperties: false
            class: org.quartz.impl.jdbcjobstore.JobStoreTX
            tablePrefix: QRTZ_ # using upper case here has better compatible#
            dataSource: cyberdata
            driverDelegateClass: org.quartz.impl.jdbcjobstore.StdJDBCDelegate
            isClustered: true
            clusterCheckinInterval: 5000
            acquireTriggersWithinLock: true
          threadPool:
            class: org.quartz.simpl.SimpleThreadPool
            makeThreadsDaemons: true
            threadCount: 10
            threadPriority: 5
            #threadsInheritContextClassLoaderOfInitializingThread: true
    job-store-type: jdbc
  jpa:
    open-in-view: false
    show-sql: false
  #redis#
  redis:
    database: 0
    host: 10.131.3.116
    port: 6379
    password: XHB5yL*UvxCvcbGC
    # redis连接超时时间（单位毫秒）:不能设置为0，否则报无法连接
    timeout: 60s
    # redis高级客户端:springboot2.0之后将连接池由jedis改为lettuce #
    lettuce:
      pool:
        max-active: 200  # 连接池最大连接数（使用负值表示没有限制）
        max-idle: 50      # 连接池中的最大空闲连接
        min-idle: 8       # 连接池中的最小空闲连接    
  mvc:
    pathmatch:
      # 配置策略
      matching-strategy: ant-path-matcher

cyber:
  user:
    base:
      baseUrl: http://localhost:8080/
      sysUser: sdkAuth/sysUser
      permissionAll: sdkAuth/permissionAll
      addOperationLog: sdkAuth/add/operationLog
      extendExpiration: sdkAuth/extendExpiration
      expiration: 43200
      #指定时间内失败次数，超出该次数即锁定，比如在120s之内连续失败5次即锁定账号,默认不开启锁定功能
      lockErrorCount: 3
      #指定时间内失败次数，该时间段内失败超出指定次数即锁定，比如在120s之内连续失败5次即锁定账号，单位秒,如果开启锁定功能，默认120s
      lockErrorTime: 120
      # #锁定时间，单位秒，默认600s
      lockTime: 600
    auth:
      rules:
        - /sdkAuth/**
        - /sys/error
        - /heartbeat/**
        - /user/check/token**
        - /captcha
        - /auth/loginWithCaptcha
        - /auth/login
        - /auth/loginWithCode
        - /auth/captchaEnabled
        - /auth/getThirdLoginUrl
        - /auth/getThirdLogoutUrl
        - /permission/import/**
        - /role/permission/init**
        - /migration/history-role/**
        - /migration/project-user-role/**
        # 审批中心接口
        - /approval/flow/submit
        - /approval/flow/latest
        - /deploy/applyAuditCallBack
        - /logic/model/auditCallBack
        - /asset/approval/handle
        #元数据安全等级变更审批回调接口
        - /metaserver/metadata/security/level/apply/approval
        - /tenant/businessSystem/external/**
        # 审批中心接口
        - /model/column/api/**

#安全配置
security:
  # 验证码
  captcha:
    # true:开启验证码登录，false:关闭验证码登录
    enabled: true
    # type: math 数字计算 type: char 字符
    type: math

